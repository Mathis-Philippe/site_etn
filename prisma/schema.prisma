generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Client {
  id         String   @id @default(uuid())
  codeClient String   @unique
  email         String?  @unique
  password   String?  // Optionnel : Null tant qu'il ne s'est pas connecté
  nomEntreprise String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ResetToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())
}