generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite" // Ou PostgreSQL si tu déploies sur Vercel avec Supabase/Neon
  url      = env("DATABASE_URL")
}

model Client {
  id         String   @id @default(uuid())
  codeClient String   @unique
  password   String?  // Optionnel : Null tant qu'il ne s'est pas connecté
  nomEntreprise String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}