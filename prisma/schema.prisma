generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Product {
  id            Int      @id @default(autoincrement())
  name          String
  category      String
  price         Float
  originalPrice Float?
  image         String
  rating        Float    @default(0)
  reviews       Int      @default(0)
  inStock       Boolean  @default(true)
  badge         String?
  description   String
  specs         String   @default("[]") 
}